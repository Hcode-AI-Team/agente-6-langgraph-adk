# =============================================================
# Banco BV — Credit-Policy Orchestrator
# Copy this file to .env and fill in your values.
# See docs/SETUP.md for a full explanation of each variable.
# =============================================================

# --- Google Cloud Platform ---
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
# Required by google.genai / Google ADK LlmAgent so it uses Vertex AI (not Gemini API key).
GOOGLE_GENAI_USE_VERTEXAI=TRUE
# Optional: path to a service-account JSON key (use ADC if unset).
GOOGLE_APPLICATION_CREDENTIALS=./credentials.json

# --- Vertex AI Vector Search ---
# Full resource names (preferred, unambiguous across projects/regions).
VECTOR_SEARCH_INDEX_NAME=projects/<PROJECT_NUMBER>/locations/<REGION>/indexes/<INDEX_ID>
VECTOR_SEARCH_INDEX_ENDPOINT_NAME=projects/<PROJECT_NUMBER>/locations/<REGION>/indexEndpoints/<ENDPOINT_ID>
VECTOR_SEARCH_DEPLOYED_INDEX_ID=deployed_credit_policy
# Optional: GCS bucket used to stage RAG datapoints / streaming updates.
GOOGLE_CLOUD_STORAGE_BUCKET=<bucket-de-staging-rag>
VERTEX_EMBEDDING_MODEL=text-embedding-004
VERTEX_RAG_TOP_K=5

# --- LLM (evaluator and synthesis nodes) ---
VERTEX_LLM_MODEL=gemini-2.5-flash
VERTEX_LLM_TEMPERATURE=0.2

# --- Google ADK — Remote Risk Specialist Agent (A2A) ---
# When running the risk-agent locally with `python run_risk_agent.py`:
ADK_RISK_AGENT_CARD_URL=http://127.0.0.1:8080/a2a/risk_agent/.well-known/agent-card.json
# When the risk-agent is deployed (e.g. Cloud Run):
#   ADK_RISK_AGENT_CARD_URL=https://<service>.run.app/a2a/risk_agent/.well-known/agent-card.json
ADK_RISK_AGENT_TIMEOUT=180

# --- Observability ---
LOG_LEVEL=INFO
